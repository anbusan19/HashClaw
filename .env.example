# ── Network ───────────────────────────────────────────────────────────────────
HASHKEY_RPC_URL=https://testnet.hsk.xyz
HASHKEY_CHAIN_ID=133

# ── Deployer wallet ───────────────────────────────────────────────────────────
PRIVATE_KEY=0xyour_private_key_here

# ── AI / Groq ─────────────────────────────────────────────────────────────────
# Get from: console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here  # @BotFather → /newbot

# ── Deployed contract addresses (filled automatically by: pnpm deploy) ────────
TREASURY_VAULT_ADDRESS=
REBALANCE_EXECUTOR_ADDRESS=
HSP_SETTLEMENT_ADDRESS=

# ── HashKey Chain RWA / ecosystem contract addresses ─────────────────────────
# Obtain from HashKey Chain docs or ecosystem partners post-launch
VEHSK_ADDRESS=
RWA_SILVER_ADDRESS=
RWA_MMF_ADDRESS=

# ── Agent tuning ──────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=60000    # how often the agent checks and potentially rebalances (ms)
